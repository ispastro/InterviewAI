# ================================
# InterviewMe Backend - Environment Variables
# ================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database (Heroku will auto-set this)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/interviewme

# Auth (must match NextAuth.js secret)
JWT_SECRET=your-super-secret-key-change-this
JWT_ALGORITHM=HS256

# Groq AI
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Upstash Redis (serverless caching - optional)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here
REDIS_ENABLED=false
CACHE_TTL_SECONDS=3600

# App
CORS_ORIGINS=["http://localhost:3000"]
ENVIRONMENT=development
